
            
<link rel="stylesheet" href="/css/finalizarCompra.css">
<main class="container py-4">
    <div class="step-indicator mb-5">
        <div class="step-item">
            <div class="step-circle completed">
                <i class="bi bi-check-lg"></i>
            </div>
            <span class="step-label">Carrinho</span>
        </div>
        <div class="step-arrow">→</div>
        <div class="step-item">
            <div class="step-circle active">2</div>
            <span class="step-label">Endereço</span>
        </div>
        <div class="step-arrow">→</div>
        <div class="step-item">
            <div class="step-circle">3</div>
            <span class="step-label">Pagamento</span>
        </div>
        <div class="step-arrow">→</div>
        <div class="step-item">
            <div class="step-circle">4</div>
            <span class="step-label">Confirmação</span>
        </div>
    </div>

    <div id="step-content" class="row g-4">
        <div class="col-lg-8">
            <section id="payment-section">
                <h2 class="section-title mb-4">Forma de pagamento</h2>

                <div class="payment-methods mb-4">
                    <div class="payment-method selected" data-method="credit">
                        <div class="d-flex align-items-center gap-3">
                            <div class="payment-radio">
                                <div class="payment-radio-inner"></div>
                            </div>
                            <i class="bi bi-credit-card payment-icon"></i>
                            <div class="flex-fill">
                                <h4 class="payment-name">Cartão de Crédito</h4>
                                <p class="payment-description">Em até 12x sem juros</p>
                            </div>
                        </div>
                    </div>

                    <div class="payment-method" data-method="pix">
                        <div class="d-flex align-items-center gap-3">
                            <div class="payment-radio">
                                <div class="payment-radio-inner"></div>
                            </div>
                            <i class="bi bi-qr-code payment-icon"></i>
                            <div class="flex-fill">
                                <h4 class="payment-name">PIX</h4>
                                <p class="payment-description">Aprovação instantânea</p>
                            </div>
                        </div>
                    </div>

                    <div class="payment-method" data-method="boleto">
                        <div class="d-flex align-items-center gap-3">
                            <div class="payment-radio">
                                <div class="payment-radio-inner"></div>
                            </div>
                            <i class="bi bi-file-earmark-text payment-icon"></i>
                            <div class="flex-fill">
                                <h4 class="payment-name">Boleto Bancário</h4>
                                <p class="payment-description">Vencimento em 3 dias</p>
                            </div>
                        </div>
                    </div>

                    <div class="payment-method" data-method="wallet">
                        <div class="d-flex align-items-center gap-3">
                            <div class="payment-radio">
                                <div class="payment-radio-inner"></div>
                            </div>
                            <i class="bi bi-wallet2 payment-icon"></i>
                            <div class="flex-fill">
                                <h4 class="payment-name">Carteira Digital</h4>
                                <p class="payment-description">PayPal, PicPay, Mercado Pago</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="payment-details" class="card checkout-card p-4 mb-4">
                    <h3 class="payment-details-title mb-4">Dados do cartão</h3>

                    <div class="mb-3">
                        <label class="form-label">Número do cartão</label>
                        <input id="card-number" type="text" class="form-control" placeholder="0000 0000 0000 0000">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Nome no cartão</label>
                        <input id="card-name" type="text" class="form-control" placeholder="João Silva">
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Validade</label>
                            <input id="card-exp" type="text" class="form-control" placeholder="MM/AA">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">CVV</label>
                            <input id="card-cvv" type="text" class="form-control" placeholder="123">
                        </div>
                    </div>

                    <div class="mt-3" id="parcelas">
                        <!-- Logica aplicada do script finalizarCompra -->
                    </div>
                </div>

                <button id="btn-back" class="btn btn-outline-primary">
                    ← Voltar para endereço
                </button>
            </section>
        </div>

        <div class="col-lg-4">
            <div class="order-summary">
                <h3 class="summary-title mb-4">Resumo do pedido</h3>

                <div class="summary-items mb-4" id="listaValores">
                    <!-- Logica aplicada do script finalizarCompra -->
                </div>

                <button id="btn-pagamento" class="btn btn-primary btn-checkout w-100 mb-3">
                    Finalizar Compra
                </button>

                <div class="security-badge">
                    Compra 100% segura e protegida
                </div>
            </div>
        </div>
    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/cleave.js@1/dist/cleave.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const cleaveCard = new Cleave('#card-number', {
            creditCard: true,
            onCreditCardTypeChanged: function (type) {
                console.log('Bandeira:', type);
            }
        });

        const cleaveExp = new Cleave('#card-exp', {
            date: true,
            datePattern: ['m', 'y']
        });

        const cleaveCvv = new Cleave('#card-cvv', {
            numeral: true,
            numeralIntegerScale: 4,
            numeralPositiveOnly: true,
            stripLeadingZeroes: false
        });
    });
</script>

